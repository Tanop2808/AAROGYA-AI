# ─── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/sehat-setu

# ─── NextAuth ──────────────────────────────────────────────────────────────
# REQUIRED: Set to your deployed URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# REQUIRED: Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=your-strong-random-secret-here

# ─── Legacy JWT (still used by /api/auth/login REST endpoint) ─────────────
JWT_SECRET=your-strong-random-secret-here

# ─── Anthropic AI ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Fast2SMS (OTP SMS) ────────────────────────────────────────────────────
# Sign up free at https://www.fast2sms.com → Dashboard → Dev API
# You get ₹50 free credits on signup (~200 OTPs)
FAST2SMS_API_KEY=your-fast2sms-api-key-here
